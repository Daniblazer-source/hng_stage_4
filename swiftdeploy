#!/usr/bin/env python3
import sys
import os
import subprocess
import time
import json
import shutil
from datetime import datetime, timezone

# --- Dependency Guard ---
try:
    import yaml
    import requests
    from jinja2 import Template
except ImportError:
    print("Error: Missing dependencies. Run 'pip install pyyaml requests jinja2'")
    sys.exit(1)

MANIFEST_FILE = "manifest.yaml"
HISTORY_FILE = "history.jsonl"
OPA_URL = "http://127.0.0.1:8181/v1/data/swiftdeploy"
TEMPLATE_FILE = "templates/docker-compose.j2"

def load_manifest():
    if not os.path.exists(MANIFEST_FILE):
        print(f"Error: {MANIFEST_FILE} not found.")
        sys.exit(1)
    with open(MANIFEST_FILE, 'r') as f:
        return yaml.safe_load(f)

def ensure_opa_running():
    """Ensures the OPA gate is active before querying policies."""
    print("🛡️  Verifying Policy Gate (OPA)...")
    try:
        # Check if the OPA container is running
        result = subprocess.run(['docker', 'ps', '--filter', 'name=opa', '--quiet'], capture_output=True, text=True)
        if not result.stdout.strip():
            print("🚀 OPA is not running. Initializing Security Gate...")
            # We use the 'opa' service defined in your docker-compose.yml
            subprocess.run(['docker', 'compose', 'up', '-d', 'opa'], check=True)
            print("⏳ Waiting for OPA to initialize...")
            time.sleep(3) # Give OPA time to load policies from the volume
        else:
            print("✅ Policy Gate is active.")
    except Exception as e:
        print(f"⚠️  Warning: Could not auto-start OPA: {e}")

def generate_config():
    """Generates docker-compose.yml from the Jinja2 template."""
    config = load_manifest()
    if not os.path.exists(TEMPLATE_FILE):
        print(f"Error: {TEMPLATE_FILE} not found.")
        return
    with open(TEMPLATE_FILE, 'r') as f:
        template = Template(f.read())

    rendered = template.render(config=config)
    with open("docker-compose.yml", "w") as f:
        f.write(rendered)
    print("✔ Generated docker-compose.yml from template.")

def log_audit(event_type, data, result_list):
    entry = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "event": event_type,
        "input_data": data,
        "opa_result": result_list
    }
    with open(HISTORY_FILE, "a") as f:
        f.write(json.dumps(entry) + "\n")

def query_opa(domain, input_data, retries=5):
    """STRICT: No skipping. Must connect to OPA or fail."""
    print(f"🔍 Querying OPA Policy: {domain}...")
    for i in range(retries):
        try:
            url = f"{OPA_URL}/{domain}"
            response = requests.post(url, json={"input": input_data}, timeout=5)
            if response.status_code == 200:
                res_json = response.json().get("result")
                if res_json is not None:
                    denials = res_json.get("violation", [])
                    log_audit(f"check_{domain}", input_data, denials)
                    return (False, denials) if denials else (True, [])
            print(f"⏳ OPA responding, but policy not ready... ({i+1}/{retries})")
        except Exception as e:
            print(f"⏳ Connection failed: {e}. Retrying... ({i+1}/{retries})")
        time.sleep(2)
    return False, ["Could not connect to Policy Engine after retries"]

def get_host_stats():
    """Fetches real host metrics for OPA evaluation."""
    _, _, free = shutil.disk_usage("/")
    cpu_load = os.getloadavg()[0] if hasattr(os, 'getloadavg') else 0.5
    return {
        "disk_free_gb": free // (2**30),
        "cpu_load": round(cpu_load, 2)
    }

def status():
    """Live-refreshing terminal dashboard."""
    print("--- SwiftDeploy Live Status ---")
    print("Press Ctrl+C to exit.")
    try:
        while True:
            os.system('cls' if os.name == 'nt' else 'clear')
            print(f"Time: {datetime.now().strftime('%H:%M:%S')}")
            try:
                # Assuming port 3000 as per your previous setup
                m = requests.get("http://localhost:3000/metrics", timeout=2).text
                print(f"📈 Metrics Scraped: Found {len(m.splitlines())} lines.")
            except:
                print("📈 Metrics: API Unreachable")

            stats = get_host_stats()
            print(f"🖥  Host: CPU Load: {stats['cpu_load']} | Disk Free: {stats['disk_free_gb']}GB")
            log_audit("status_scrape", stats, [])
            time.sleep(5)
    except KeyboardInterrupt:
        print("\nExiting status dashboard.")

def deploy():
    # 0. Ensure OPA is running first!
    ensure_opa_running()

    # 1. Pre-deploy Policy Check
    print("--- Pre-Deploy: Infrastructure Policy Check ---")
    infra_data = get_host_stats()
    allowed, reasons = query_opa("infra", infra_data)

    if not allowed:
        print(f"❌ DEPLOY BLOCKED by Policy: {reasons}")
        sys.exit(1)

    print("✅ Infrastructure standards met. Proceeding with deployment...")

    # 2. Trigger Container Lifecycle
    try:
        subprocess.run(['docker', 'compose', 'up', '-d'], check=True)
    except:
        subprocess.run(['docker-compose', 'up', '-d'], check=True)
    print("✔ Stack is up and healthy.")

def audit():
    if not os.path.exists(HISTORY_FILE):
        print("❌ No history file found.")
        return
    with open("audit_report.md", "w") as r:
        r.write("# SwiftDeploy Audit Report\n\n")
        r.write("## Policy Compliance Timeline\n\n")
        r.write("| Timestamp | Event | Status | Details |\n|---|---|---|---|\n")
        with open(HISTORY_FILE, "r") as f:
            for line in f:
                d = json.loads(line)
                if d['event'] == "status_scrape": continue
                res = "❌ FAIL" if d['opa_result'] else "✅ PASS"
                det = ", ".join(d['opa_result']) if d['opa_result'] else "Compliant"
                r.write(f"| {d['timestamp']} | {d['event']} | {res} | {det} |\n")
    print("✔ Generated audit_report.md")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: ./swiftdeploy [init|deploy|status|audit|teardown]")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == "init": generate_config()
    elif cmd == "deploy": deploy()
    elif cmd == "status": status()
    elif cmd == "audit": audit()
    elif cmd == "teardown":
        try: subprocess.run(['docker', 'compose', 'down'])
        except: subprocess.run(['docker-compose', 'down'])
