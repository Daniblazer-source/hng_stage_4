#!/usr/bin/env python3
import sys
import os
import subprocess
import time

# --- Dependency Guard ---
try:
    import yaml
    from jinja2 import Template
except ImportError:
    print("Error: Missing dependencies. Run 'pip install -r app/requirements.txt'")
    sys.exit(1)

MANIFEST_FILE = "manifest.yaml"

def load_manifest():
    if not os.path.exists(MANIFEST_FILE):
        print(f"Error: {MANIFEST_FILE} not found.")
        sys.exit(1)
    with open(MANIFEST_FILE, 'r') as f:
        return yaml.safe_load(f)

def save_manifest(config):
    with open(MANIFEST_FILE, 'w') as f:
        yaml.dump(config, f, default_flow_style=False)

def init():
    print("Initializing configurations...")
    config = load_manifest()
    mode = config.get('mode', 'stable')

    # 1. Generate Docker Compose
    with open('templates/docker-compose.j2') as f:
        tmpl = Template(f.read())
        rendered = tmpl.render(
            image=config['services']['image'],
            port=config['services']['port'],
            network_name=config['network']['name'],
            mode=mode,
            nginx_port=config['nginx']['port']  # <--- THIS WAS MISSING
        )
        with open('docker-compose.yml', 'w') as out:
            out.write(rendered)

    # 2. Generate Nginx Config
    with open('templates/nginx.conf.j2') as f:
        tmpl = Template(f.read())
        rendered = tmpl.render(
            nginx_port=config['nginx']['port'],
            proxy_timeout=config['nginx'].get('proxy_timeout', '60s'),
            service_port=config['services']['port']
        )
        with open('nginx.conf', 'w') as out:
            out.write(rendered)

    print("✔ Generated docker-compose.yml and nginx.conf")

def validate():
    print("--- Pre-flight Checks ---")
    config = load_manifest()
    passed = True

    # 1. YAML Validation (Done by load_manifest)
    print("✔ Manifest is valid YAML")

    # 2. Field Check
    required = ['services', 'nginx', 'network']
    if all(k in config for k in required):
        print("✔ All required fields present")
    else:
        print("✘ Missing required fields"); passed = False

    # 3. Docker Image Check
    img = config['services']['image']
    check_img = subprocess.run(['docker', 'inspect', img], capture_output=True)
    if check_img.returncode != 0:
        print(f"✘ Image {img} not found locally"); passed = False
    else:
        print(f"✔ Image {img} exists locally")

    # 4. Port Check (Nginx Port)
    n_port = config['nginx']['port']
    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        if s.connect_ex(('localhost', n_port)) == 0:
            print(f"✘ Port {n_port} is already bound on host"); passed = False
        else:
            print(f"✔ Port {n_port} is available")

    # 5. Nginx Syntax Check (Using Nginx Docker image to validate generated file)
    if os.path.exists('nginx.conf'):
        val_cmd = f"docker run --rm -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf:ro nginx:latest nginx -t"
        if subprocess.run(val_cmd, shell=True, capture_output=True).returncode == 0:
            print("✔ Generated nginx.conf is syntactically valid")
        else:
            print("✘ nginx.conf syntax error"); passed = False

    if not passed:
        print("\nVALIDATION FAILED")
        sys.exit(1)
    print("\nVALIDATION PASSED")

def deploy():
    validate() # Best practice: validate before deploy
    init()
    print("Starting stack...")
    subprocess.run(['docker-compose', 'up', '-d'])

    # 60s Healthcheck loop
    config = load_manifest()
    url = f"http://localhost:{config['nginx']['port']}/healthz"
    print(f"Waiting for healthcheck at {url}...")
    
    start = time.time()
    while time.time() - start < 60:
        try:
            import requests
            r = requests.get(url, timeout=2)
            if r.status_code == 200:
                print(f"✔ Stack is healthy ({int(time.time() - start)}s)")
                return
        except:
            pass
        time.sleep(2)
    
    print("✘ Deployment timed out!")
    sys.exit(1)

def promote(target_mode):
    if target_mode not in ['canary', 'stable']:
        print("Error: Target mode must be 'canary' or 'stable'")
        sys.exit(1)
    
    print(f"Promoting to {target_mode}...")
    config = load_manifest()
    config['mode'] = target_mode
    save_manifest(config)
    
    init() # Regenerate configs with new MODE
    subprocess.run(['docker-compose', 'up', '-d', '--no-deps', 'api'])
    print(f"✔ Switched to {target_mode}")

def teardown(clean=False):
    print("Tearing down stack...")
    subprocess.run(['docker-compose', 'down'])
    if clean:
        for f in ['docker-compose.yml', 'nginx.conf']:
            if os.path.exists(f):
                os.remove(f)
        print("✔ Cleaned up generated files")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: ./swiftdeploy [init|validate|deploy|promote|teardown]")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == "init": init()
    elif cmd == "validate": validate()
    elif cmd == "deploy": deploy()
    elif cmd == "promote":
        if len(sys.argv) < 3:
            print("Usage: ./swiftdeploy promote [stable|canary]")
        else:
            promote(sys.argv[2])
    elif cmd == "teardown":
        clean = "--clean" in sys.argv
        teardown(clean)
