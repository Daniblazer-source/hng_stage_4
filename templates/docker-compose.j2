services:
  api:
    image: {{ image }}
    environment:
      - MODE={{ mode }}
      - APP_PORT={{ port }}
    networks:
      - {{ network_name }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    user: "1000:1000"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ port }}/healthz')"]
      interval: 10s
    volumes:
      - api_logs:/var/log/app

  nginx:
    image: nginx:latest
    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      - {{ network_name }}
    depends_on:
      - api

networks:
  {{ network_name }}:
    driver: bridge

volumes:
  api_logs:
